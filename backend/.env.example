 # Локальная разработка (backend/.env). Пароль должен совпадать с POSTGRES_PASSWORD
# в корневом .env, если PostgreSQL поднимается через docker compose.
DATABASE_URL=postgresql://sylla:change-me-local-postgres-password@localhost:5432/syllanote
JWT_SECRET=change-me-local-jwt-secret-min-8-chars
JWT_EXPIRES_IN=7d
PORT=3000
WS_PORT=8080
BCRYPT_ROUNDS=10
# all | api | ws  (на Render: два сервиса с api и ws)
SERVICE_MODE=all
# Дополнительные origin для CORS (через запятую). *.onrender.com разрешён автоматически.
# CORS_ORIGINS=https://syllanote-frontend.onrender.com
# Render Free (без Shell): POST /api/dev/seed с заголовком X-Seed-Secret (только на api-сервисе)
# SEED_SECRET=замените-на-длинный-случайный-секрет
