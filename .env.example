# Скопируйте в .env в корне репозитория перед `docker compose up`:
#   cp .env.example .env
# Задайте собственные значения; файл .env не коммитится в Git.

POSTGRES_USER=sylla
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_DB=syllanote

DATABASE_URL=postgresql://sylla:change-me-local-postgres-password@postgres:5432/syllanote
JWT_SECRET=change-me-local-jwt-secret-min-8-chars
JWT_EXPIRES_IN=7d
PORT=3000
WS_PORT=8080
BCRYPT_ROUNDS=10
